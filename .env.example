# ===========================================
# Peptidesfarma Environment Variables
# ===========================================

# ---- Vercel ----
VERCEL_TOKEN=

# ---- DigitalOcean ----
DO_API_TOKEN=

# ---- Backend (Medusa) ----
DATABASE_URL=postgresql://medusa:medusa@localhost:5432/peptidesfarma
REDIS_URL=redis://localhost:6379
MEDUSA_ADMIN_ONBOARDING_TYPE=default
STORE_CORS=http://localhost:3000,https://peptidesfarma.com,https://www.peptidesfarma.com
ADMIN_CORS=http://localhost:9000,https://admin.peptidesfarma.com
AUTH_CORS=http://localhost:3000,https://peptidesfarma.com,https://www.peptidesfarma.com
COOKIE_SECRET=your-cookie-secret-here
JWT_SECRET=your-jwt-secret-here
BACKEND_URL=http://localhost:9000

# ---- Stripe ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ---- Square ----
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_ENVIRONMENT=sandbox
NEXT_PUBLIC_SQUARE_APP_ID=
NEXT_PUBLIC_SQUARE_LOCATION_ID=

# ---- Shippo ----
SHIPPO_API_KEY=

# ---- Resend (Email) ----
RESEND_API_KEY=
RESEND_FROM_EMAIL=orders@peptidesfarma.com
ADMIN_NOTIFICATION_EMAIL=admin@peptidesfarma.com

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://peptidesfarma.com/api/auth/google/callback

# ---- Apple Sign In ----
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# ---- DigitalOcean Spaces (File Storage) ----
SPACE_URL=
SPACE_BUCKET=
SPACE_ENDPOINT=
SPACE_ACCESS_KEY_ID=
SPACE_SECRET_ACCESS_KEY=
SPACE_REGION=

# ---- Tax ----
ZIP_TAX_API_KEY=

# ---- Analytics ----
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# ---- Klaviyo ----
KLAVIYO_PRIVATE_API_KEY=
NEXT_PUBLIC_KLAVIYO_COMPANY_ID=

# ---- Intercom ----
NEXT_PUBLIC_INTERCOM_APP_ID=

# ---- Storefront ----
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=
NEXT_PUBLIC_STORE_URL=https://peptidesfarma.com
REVALIDATION_SECRET=
