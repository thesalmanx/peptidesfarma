{
  "redirects": [
    {
      "source": "/product-page/:handle",
      "destination": "/product/:handle",
      "permanent": true
    },
    {
      "source": "/shop/:handle",
      "destination": "/product/:handle",
      "permanent": true
    },
    {
      "source": "/shop",
      "destination": "/products",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/stripe/renew",
      "schedule": "0 8 * * *"
    }
  ]
}
